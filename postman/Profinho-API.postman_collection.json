    {
      "name": "Agente",
      "item": [
        {
          "name": "Executar agente",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    const json = pm.response.json();",
                  "    if (json.projeto) pm.collectionVariables.set('projeto', json.projeto);",
                  "    if (json.sessao_id) pm.collectionVariables.set('sessao_id', json.sessao_id);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"instrucao\": \"Crie um script Python hello_world.py que imprime 'Olá Profinho'\",\n  \"projeto\": \"{{projeto}}\",\n  \"validar\": true,\n  \"usar_web\": false,\n  \"max_iteracoes\": 4\n}"
            },
            "url": "{{baseUrl}}/agent/run",
            "description": "Agente estilo Cursor: cria arquivos, escreve código e valida."
          }
        },
        {
          "name": "Listar arquivos do projeto",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/agent/projects/{{projeto}}/files"
          }
        },
        {
          "name": "Ler arquivo do projeto",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/agent/projects/{{projeto}}/file?path=hello_world.py",
              "host": ["{{baseUrl}}"],
              "path": ["agent", "projects", "{{projeto}}", "file"],
              "query": [
                {
                  "key": "path",
                  "value": "hello_world.py",
                  "description": "Caminho relativo no projeto"
                }
              ]
            }
          }
        },
        {
          "name": "Executar comando no projeto",
          "request": {
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/agent/projects/{{projeto}}/exec?comando=python hello_world.py",
              "host": ["{{baseUrl}}"],
              "path": ["agent", "projects", "{{projeto}}", "exec"],
              "query": [
                {
                  "key": "comando",
                  "value": "python hello_world.py"
                }
              ]
            },
            "description": "Executa comando de validação no workspace do agente."
          }
        }
      ]
    },
