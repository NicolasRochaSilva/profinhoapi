      ]
    },
    {
      "name": "Ollama (RAM)",
      "description": "Gerenciamento de modelos na RAM. Modelos quentes (não descarregam via unload): llama3.2:3b, llama3.1:8b, qwen2.5-coder:7b, qwen2.5:7b.",
      "item": [
        {
          "name": "Pré-aquecer 4 modelos quentes",
          "request": {
            "method": "POST",
            "header": [],
            "url": "{{baseUrl}}/ollama/preload",
            "description": "Carrega na RAM: llama3.2:3b (roteador), llama3.1:8b (chat), qwen2.5-coder:7b, qwen2.5:7b. Pode levar vários minutos. Usa OLLAMA_QUENTES_KEEP_ALIVE (padrão -1 = Forever)."
          }
        },
        {
          "name": "Modelos carregados",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/ollama/loaded",
            "description": "Lista modelos atualmente na RAM (`/api/ps`)."
          }
        },
        {
          "name": "Descarregar todos",
          "request": {
            "method": "POST",
            "header": [],
            "url": "{{baseUrl}}/ollama/unload",
            "description": "Descarrega modelos da RAM. Os 4 modelos quentes são protegidos e não são descarregados."
          }
        },
        {
          "name": "Descarregar modelo específico",
          "request": {
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/ollama/unload?model=llama3.1:8b",
              "host": ["{{baseUrl}}"],
              "path": ["ollama", "unload"],
              "query": [
                {
                  "key": "model",
                  "value": "llama3.1:8b",
                  "description": "Nome do modelo Ollama"
                }
              ]
            },
            "description": "Descarrega um modelo específico da RAM."
          }
        }
      ]
    },
    {
      "name": "Chat",
      "item": [
        {
          "name": "Roteamento (só decide modelo)",
          "request": {
