        {
          "name": "Chat completions (coder)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"model\": \"profinho-coder\",\n  \"messages\": [\n    { \"role\": \"system\", \"content\": \"Você é um assistente de código.\" },\n    { \"role\": \"user\", \"content\": \"Gere um Dockerfile multi-stage para esta API FastAPI\" }\n  ],\n  \"temperature\": 0.2,\n  \"stream\": false\n}"
            },
            "url": "{{baseUrl}}/v1/chat/completions"
          }
        },
        {
          "name": "Chat completions (stream)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    let accumulated = \"\";",
                  "    const lines = pm.response.text().split(\"\\n\");",
                  "    for (const line of lines) {",
                  "        if (!line.startsWith(\"data: \")) continue;",
                  "        const raw = line.slice(6).trim();",
                  "        if (raw === \"[DONE]\") break;",
                  "        try {",
                  "            const chunk = JSON.parse(raw);",
                  "            const delta = chunk.choices && chunk.choices[0] && chunk.choices[0].delta;",
                  "            if (delta && delta.content) accumulated += delta.content;",
                  "        } catch (e) {}",
                  "    }",
                  "    pm.collectionVariables.set(\"stream_text\", accumulated);",
                  "    pm.test(\"SSE OpenAI\", () => pm.expect(pm.response.headers.get(\"Content-Type\")).to.include(\"text/event-stream\"));",
                  "    pm.test(\"Tokens recebidos\", () => pm.expect(accumulated.length).to.be.above(0));",
                  "    console.log(\"OpenAI stream:\", accumulated);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Accept", "value": "text/event-stream" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"model\": \"profinho-chat\",\n  \"messages\": [\n    { \"role\": \"user\", \"content\": \"Olá, quem é você?\" }\n  ],\n  \"stream\": true\n}"
            },
            "url": "{{baseUrl}}/v1/chat/completions",
            "description": "Formato OpenAI SSE: `data: {...}` com `delta.content` token a token. Acumula em `{{stream_text}}`."
          }
        },
        {
          "name": "Chat completions (stream — coder)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    let accumulated = \"\";",
                  "    pm.response.text().split(\"\\n\").forEach(line => {",
                  "        if (!line.startsWith(\"data: \")) return;",
                  "        const raw = line.slice(6).trim();",
                  "        if (raw === \"[DONE]\") return;",
                  "        try {",
                  "            const c = JSON.parse(raw);",
                  "            const d = c.choices && c.choices[0] && c.choices[0].delta;",
                  "            if (d && d.content) accumulated += d.content;",
                  "        } catch (e) {}",
                  "    });",
                  "    pm.collectionVariables.set(\"stream_text\", accumulated);",
                  "    console.log(accumulated);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Accept", "value": "text/event-stream" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"model\": \"profinho-coder\",\n  \"messages\": [\n    { \"role\": \"user\", \"content\": \"Função Python que soma dois números\" }\n  ],\n  \"stream\": true,\n  \"temperature\": 0.2\n}"
            },
            "url": "{{baseUrl}}/v1/chat/completions"
          }
        }
