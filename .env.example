# ==========================================================
# Profinho API - variáveis de ambiente
# Copie para .env e ajuste conforme o ambiente
# ==========================================================

# --- API ---
API_HOST=0.0.0.0
API_PORT=7000
API_TITLE=Profinho API
ENVIRONMENT=production
# Se vazio, a autenticação por token continua exigida mas nenhum token "mestre" é criado.
# Token mestre opcional (sempre válido), útil para administração/bootstrap.
MASTER_TOKEN=

# --- Ollama (rodando no HOST da VPS, fora do Docker) ---
# Dentro do container usamos host.docker.internal (mapeado em extra_hosts).
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_TIMEOUT=600
# Tempo que o modelo fica na RAM após o último uso ("5m", "30s", "0" = descarrega na hora).
OLLAMA_KEEP_ALIVE=5m
# Modelos quentes (llama3.2:3b, llama3.1:8b, qwen2.5-coder:7b, qwen2.5:7b): "-1" = sempre na RAM.
OLLAMA_QUENTES_KEEP_ALIVE=-1
OLLAMA_PRELOAD_QUENTES=true
# Visão (qwen2.5vl:7b) usa OLLAMA_KEEP_ALIVE (padrão 5m), carrega só quando necessário.
# true = mantém só 1 modelo pesado na RAM por vez (descarrega os outros antes de usar).
OLLAMA_MODELO_UNICO=true

# --- Modelos (um por finalidade) ---
MODEL_ROUTER=llama3.2:3b
MODEL_CHAT=llama3.1:8b
MODEL_CODE=qwen2.5-coder:7b
MODEL_EDU=qwen2.5:7b
MODEL_VISION=qwen2.5vl:7b

# --- PostgreSQL ---
POSTGRES_HOST=92.113.34.26
POSTGRES_PORT=5432
POSTGRES_DB=profinho
POSTGRES_USER=postgres
POSTGRES_PASSWORD=134497Nico@

# --- SearXNG (no docker-compose) ---
SEARXNG_BASE_URL=http://searxng:8080

# --- Crawl4AI (no docker-compose) ---
CRAWL4AI_BASE_URL=http://crawl4ai:11235
CRAWL4AI_TOKEN=
CRAWL4AI_MAX_PAGINAS=4

# --- Agente / workspace ---
# Diretório onde o agente cria arquivos e roda código (dentro do container).
AGENT_WORKSPACE=/workspace
AGENT_EXEC_TIMEOUT=120

# --- Cache semântico (all-MiniLM-L6-v2) ---
CACHE_ENABLED=true
CACHE_SIMILARIDADE_MIN=0.88
CACHE_REFORMAT_MIN=0.95
CACHE_MAX_CANDIDATOS=300
